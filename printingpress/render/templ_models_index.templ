package render

import "github.com/pb33f/doctor/printingpress/internal/pppaths"
import ppmodel "github.com/pb33f/doctor/printingpress/model"

templ ModelsIndexTempl(groups []*ppmodel.NavModelGroup, breadcrumb []BreadcrumbItem, baseURL string) {
	<div class="pp-root">
		@Breadcrumb(baseURL, breadcrumb)
		<pp-icon-title icon="schemas" heading="Models"></pp-icon-title>
		for _, group := range groups {
			if len(group.Models) > 0 {
				<div class="pp-model-category">
					<h2>
						<a href={ templ.SafeURL(DocHref(baseURL, pppaths.ModelTypeIndexHTML(group.TypeSlug))) } class="pp-category-link">
							{ group.Name }
						</a>
					</h2>
					<div class="pp-model-cards" style={ group.CardGridStyle() }>
						for _, model := range group.Models {
							<a href={ templ.SafeURL(DocHref(baseURL, pppaths.ModelHTML(model.TypeSlug, model.Slug))) } class="pp-model-card">
								<div class="pp-model-card-title">
									<pb33f-model-icon icon={ model.TypeSlug } size="small"></pb33f-model-icon>
									<strong>{ model.Name }</strong>
								</div>
								if model.Description != "" {
									<p>{ truncateDesc(model.Description, 120) }</p>
								}
							</a>
						}
					</div>
				</div>
			}
		}
	</div>
}
